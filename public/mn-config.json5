/**
 * This file is used to configure the application's content and behavior.
 * It uses the JSON5 format, which allows for comments, trailing commas, and more.
 *
 * How it works:
 * - "defaults": Contains the default configuration for various components. These values
 *   are used if no specific override is provided.
 * - "overrides": Contains specific configuration overrides organized by route and section.
 *   - "root": The base level for overrides.
 *   - "home", "navbar", "footer": Specific areas of the application where defaults can be overridden.
 *
 * How to edit:
 * - You can change text, image URLs, and other properties within the JSON objects.
 * - Use double or single quotes for keys and string values.
 * - Ensure the JSON structure remains valid (matched braces and brackets).
 */
{
  language: {
    urlPattern: "assets/i18n/{locale}.json",
    defaultLocale: "en",
    preload: ["en", "nl"]
  },
  "defaults": {
    "mn-input-field": {
      "placeholder": "Enter text here...",
      "label": "Input field",
      "ariaLabel": "Global accessible label",
      errorMessages: {
        required: { $translate: "validation.required" },
        email: { $translate: "validation.email" }
      }
    },
    "app-parallax-component": {
      "backgroundImageUrl": "https://4kwallpapers.com/images/walls/thumbs_3t/1025.jpg",
      "description": "Description placeholder",
      "buttonText": "Learn More"
    },
    "app-section-title": {
      "title": "Title Placeholder"
    },
    "app-about-section": {
      "description": "About Us Description",
      "aboutUsButtonText": "Learn More"
    },
    "app-pictures-section": {
      "description": 'Test'
    },
    "app-packages-section": {
      "packagesTitleText": "Our packages",
      //      DO NOT EDIT THE STYLING INSIDE CARDS
      "cards": [
        {
          "title": "Card 1",
          "id": 1,
          "description": "This is card 1.",
          "bottomBorder": true,
          "borderRadius": "md",
          "shadow": true,
          "kind": "one-image",
          "image": {
            "id": 1,
            "url": "https://logo-icons.com/cdn/shop/files/2081-logo-1713630973.369.svg?v=1713641356",
            "alt": "Icon representing the Essential Retreat package"
          },
          "textPosition": "center"
        },
        {
          "id": 2,
          "title": "Card 2",
          "description": "This is card 2.",
          "kind": "one-image",
          "bottomBorder": true,
          "borderRadius": "md",
          "shadow": true,
          "image": {
            "id": 2,
            "url": "https://logo-icons.com/cdn/shop/files/2081-logo-1713630973.369.svg?v=1713641356",
            "alt": "Icon representing the Premium Retreat package"
          }
        },
        {
          "id": 3,
          "title": "Card 3",
          "description": "This is card 3.",
          "kind": "one-image",
          "bottomBorder": true,
          "borderRadius": "md",
          "shadow": true,
          "image": {
            "id": 3,
            "url": "https://logo-icons.com/cdn/shop/files/2081-logo-1713630973.369.svg?v=1713641356",
            "alt": "Icon representing the Luxury Retreat package"
          }
        }
      ]
    }
  },
  "overrides": {
    "root": {
      "home": {
        "top-section": {
          "#section-title-parallax": {
            "title": { $translate: "home.hero.title" }
          },
          "app-parallax-component": {
            "backgroundImageUrl": "/images/hero_image.webp",
            "description": { $translate: "home.hero.description" },
            "buttonText": { $translate: "home.hero.button" }
          }
        },
        "about-section": {
          "#section-title-about": {
            "title": { $translate: "home.about.title" }
          },
          "app-about-section": {
            "description": { $translate: "home.about.description" },
            "aboutUsButtonText": { $translate: "home.about.button" }
          },
          "mn-dual-horizontal-image": {
            images: [
              {
                id: '1',
                url: '/images/about_us_2.webp',
                alt: { $translate: "home.about.image1.alt" }
              },
              {
                id: '2',
                url: '/images/about_us_1.webp',
                alt: { $translate: "home.about.image2.alt" },
              }
            ]
          }
        },
        "pictures-section": {
          "#section-title-pictures": {
            "title": { $translate: "home.pictures.title" }
          },
          "app-pictures-section": {
            "description": { $translate: "home.pictures.description" },
          },
          "app-focus-carousel": {
            images: [
              {
                id: 1,
                src: '/images/carousel_1.webp',
                alt: { $translate: "home.pictures.carousel.1.alt" },
              },
              {
                id: 2,
                src: '/images/carousel_8.webp',
                alt: { $translate: "home.pictures.carousel.2.alt" },
              },
              {
                id: 3,
                src: '/images/carousel_4.webp',
                alt: { $translate: "home.pictures.carousel.3.alt" },
              },
              {
                id: 4,
                src: '/images/carousel_5.webp',
                alt: { $translate: "home.pictures.carousel.4.alt" },
              },
              {
                id: 5,
                src: '/images/carousel_6.webp',
                alt: { $translate: "home.pictures.carousel.5.alt" },
              },
              {
                id: 7,
                src: '/images/carousel_2.webp',
                alt: { $translate: "home.pictures.carousel.6.alt" },
              },
              {
                id: 10,
                src: '/images/carousel_12.webp',
                alt: { $translate: "home.pictures.carousel.7.alt" },
              }
            ]
          }
        },
        "packages-section": {
          "#section-title-packages": {
            "title": { $translate: "home.packages.title" }
          },
          "app-packages-section": {
            "packagesTitleText": { $translate: "home.packages.title" },
            "packagesDescription": { $translate: "home.packages.description" },
            "cards": [
              {
                "id": 1,
                "title": { $translate: "home.packages.essential.title" },
                "description": { $translate: "home.packages.essential.description" },
                "bottomBorder": true,
                "borderRadius": "md",
                "shadow": true,
                "image": {
                  "id": 1,
                  "url": "/images/essential_retreats.webp",
                  "alt": { $translate: "home.packages.essential.image.alt" }
                }
              },
              {
                "id": 2,
                "title": { $translate: "home.packages.premium.title" },
                "description": { $translate: "home.packages.premium.description" },
                "bottomBorder": true,
                "borderRadius": "md",
                "shadow": true,
                "image": {
                  "id": 2,
                  "url": "/images/premium_retreats.webp",
                  "alt": { $translate: "home.packages.premium.image.alt" }
                }
              },
              {
                "id": 3,
                "title": { $translate: "home.packages.luxury.title" },
                "description": { $translate: "home.packages.luxury.description" },
                "bottomBorder": true,
                "borderRadius": "md",
                "shadow": true,
                "image": {
                  "id": 3,
                  "url": "/images/luxury_retreats.webp",
                  "alt": { $translate: "home.packages.luxury.image.alt" }
                }
              }
            ]
          }
        },
        "contact-section": {
          "#section-title-getInTouch": {
            "title": { $translate: "home.contact.title" }
          },
          "app-contact-section": {
            "informationDescription": { $translate: "home.contact.informationDescription" },
            "formDescription": { $translate: "home.contact.formDescription" },
            "formButtonText": { $translate: "home.contact.formButton" },
            "emailSalutation": { $translate: "home.contact.emailSalutation" },
            "emailClosing": { $translate: "home.contact.emailClosing" },
            "contactEmail": "info@slopeworks.nl"
          },
          "#location-item": {
            "title": { $translate: "home.contact.location.title" },
            "description": { $translate: "home.contact.location.description" }
          },
          "#email-item": {
            "title": { $translate: "home.contact.email.title" },
            "description": { $translate: "home.contact.email.description" }
          },
          "#call-item": {
            "title": { $translate: "home.contact.call.title" },
            "description": { $translate: "home.contact.call.description" }
          },
          "form": {
            "#section-title-form": {
              title: { $translate: "home.contact.form.title" }
            },
            "#mn-input-name": {
              "placeholder": { $translate: "home.contact.form.name.placeholder" },
              "label": { $translate: "home.contact.form.name.label" },
              "ariaLabel": { $translate: "home.contact.form.name.ariaLabel" }
            },
            "#mn-input-subject": {
              "placeholder": { $translate: "home.contact.form.subject.placeholder" },
              "label": { $translate: "home.contact.form.subject.label" },
              "ariaLabel": { $translate: "home.contact.form.subject.ariaLabel" }
            },
            "#mn-textarea-description": {
              "placeholder": { $translate: "home.contact.form.description.placeholder" },
              "label": { $translate: "home.contact.form.description.label" },
              "ariaLabel": { $translate: "home.contact.form.description.ariaLabel" }
            }
          }
        }
      },
      "navbar": {
        "app-navbar": {
          "logoSrc": "logo_slopeworks.svg",
          "logoAlt": "SlopeWorks",
          "navItems": [
            {
              "label": { $translate: "navbar.about" },
              "sectionId": "about-section"
            },
            {
              "label": { $translate: "navbar.packages" },
              "sectionId": "packages-section"
            },
            {
              "label": { $translate: "navbar.pictures" },
              "sectionId": "pictures-section"
            }
          ],
          "contactItem": {
            "label": { $translate: "navbar.contact" },
            "sectionId": "contact-section"
          }
        }
      },
      "footer": {
        "app-footer": {
          "logoSrc": "logo_slopeworks.svg",
          "logoAlt": "SlopeWorks",
          "copyrightText": { $translate: "footer.copyright" },
          "links": [
            {
              "label": "Linkedin",
              "href": "https://www.linkedin.com/company/slopeworks/"
            },
            {
              "label": "Instagram",
              "href": "https://www.instagram.com/slopeworks_ski/"
            }
          ]
        }
      }
    }
  }
}
